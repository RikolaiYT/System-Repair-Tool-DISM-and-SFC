<Window x:Name="window" x:Class="SystemRepairTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Repair Tool"
        Height="600" Width="900"
        Background="#0f0f0f"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#00BFFF"/>
            <Setter Property="Height" Value="18"/>
        </Style>
    </Window.Resources>

    <Border Background="#151515" CornerRadius="10" Padding="15">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Text="System Repair Tool"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <!-- Статус + чекбокс -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Статус: " Foreground="#888"/>
                <TextBlock x:Name="StatusText" Text="Ожидание" Foreground="#00BFFF"/>

                <CheckBox x:Name="NetworkCheck"
                          Content="Сброс сети (DNS + Winsock)"
                          IsChecked="True"
                          Foreground="White"
                          Margin="20,0,0,0"/>
            </StackPanel>

            <!-- Прогресс -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock x:Name="StepText"
                           Text="Этап 0/0"
                           Foreground="#aaa"
                           Margin="0,0,0,5"/>

                <ProgressBar x:Name="ProgressBar"/>
            </StackPanel>

            <!-- Лог -->
            <TextBox x:Name="OutputBox"
                     Grid.Row="3"
                     Background="#111"
                     Foreground="#00BFFF"
                     FontFamily="Consolas"
                     FontSize="13"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     Padding="10"/>

            <!-- Кнопка -->
            <Button x:Name="StartButton"
                    Content="Начать"
                    Height="35"
                    Width="120"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="StartButton_Click"/>

            <!-- Футер -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">

                <TextBlock Foreground="#777" Margin="5,0">
                    <Hyperlink NavigateUri="https://github.com/RikolaiYT"
                               RequestNavigate="Link_Click">
                        GitHub
                    </Hyperlink>
                </TextBlock>

                <TextBlock Foreground="#777" Margin="5,0">|</TextBlock>

                <TextBlock Foreground="#777" Margin="5,0">
                    <Hyperlink NavigateUri="https://t.me/rikolax"
                               RequestNavigate="Link_Click">
                        Telegram
                    </Hyperlink>
                </TextBlock>

                <TextBlock Foreground="#777" Margin="5,0">|</TextBlock>

                <TextBlock Foreground="#777" Margin="5,0">
                    <Hyperlink NavigateUri="https://www.tbank.ru/cf/9KB7SGLZpie"
                               RequestNavigate="Link_Click">
                        Поддержать автора
                    </Hyperlink>
                </TextBlock>

            </StackPanel>

        </Grid>
    </Border>
</Window>